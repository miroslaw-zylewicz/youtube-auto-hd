{
  "name": "youtube-auto-hd",
  "description": "Automatically set the video quality on YouTube according to its FPS!",
  "private": true,
  "version": "1.17.3",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "repository": "https://github.com/avi12/youtube-auto-hd",
  "homepage": "https://github.com/avi12/youtube-auto-hd",
  "author": "Avi <avi6106@gmail.com>",
  "scripts": {
    "dev": "wxt",
    "dev:with-profile": "cross-env CHROME_PROFILE=Default CHROME_INSTANCE=1 wxt",
    "dev:rtl": "cross-env VITE_LANG=he wxt",
    "dev:opera": "pnpm dev -b opera",
    "dev:firefox": "wxt -b firefox --mv3",
    "dev:firefox:with-profile": "cross-env FIREFOX_PROFILE=1 wxt -b firefox --mv3",
    "dev:screenshot": "cross-env BLANK=1 LANG=szl pnpm dev",
    "dev:screenshot:opera": "pnpm dev:screenshot -b opera",
    "build": "wxt build",
    "build:opera": "pnpm build -b opera",
    "build:firefox": "pnpm build -b firefox --mv3",
    "package": "wxt zip",
    "package:opera": "pnpm package -b opera",
    "package:firefox": "pnpm package -b firefox --mv3",
    "build:package": "pnpm build && pnpm package",
    "build:package:opera": "pnpm build:opera && pnpm package:opera",
    "build:package:firefox": "pnpm build:firefox && pnpm package:firefox",
    "build:package:all": "concurrently \"pnpm build:package\" \"pnpm build:package:opera\" \"pnpm build:package:firefox\" --names Chrome,Opera,Firefox",
    "svelte:check": "svelte-check",
    "lint:fix": "eslint --fix",
    "lint:css": "stylelint . --fix",
    "postinstall": "wxt prepare"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@webext-core/messaging": "^2.3.0",
    "ccc-components": "^0.18.0",
    "nouislider": "^15.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.8.0",
    "@wxt-dev/module-svelte": "^2.0.5",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-newlines": "^2.0.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.11.1",
    "stylelint-config-ccb": "^3.31.5",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "webext-store-incompat-fixer": "^0.25.0",
    "wxt": "^0.20.26"
  }
}
